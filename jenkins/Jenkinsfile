pipeline {
    agent any
    
    environment {
        DOCKER_IMAGE = 'iris-train'
        CONTAINER_NAME = 'iris-container'
        DOCKER_IMAGE_TAG = "${DOCKER_IMAGE}:${BUILD_NUMBER}"
    }
    
    stages {
        stage('Checkout') {
            steps {
                echo 'Cloning repository...'
                checkout scm
            }
        }
        
        stage('Verify Environment') {
            steps {
                echo 'Checking environment...'
                bat '''
                    echo Current directory: %CD%
                    dir
                    echo.
                    echo Docker version:
                    docker --version
                    echo.
                    echo Git version:
                    git --version
                '''
            }
        }
        
        stage('Verify Project Structure') {
            steps {
                bat '''
                    echo Checking project structure...
                    echo.
                    echo Checking if Dockerfile exists:
                    if exist "Dockerfile" (
                        echo ✓ Dockerfile found
                        type Dockerfile
                    ) else (
                        echo ERROR: Dockerfile not found!
                        echo Creating a simple Dockerfile...
                        echo FROM python:3.11-slim > Dockerfile
                        echo WORKDIR /app >> Dockerfile
                        echo COPY . . >> Dockerfile
                        echo RUN pip install scikit-learn pandas numpy >> Dockerfile
                        echo CMD ["python", "train.py"] >> Dockerfile
                    )
                    echo.
                    echo Checking if train.py exists:
                    if exist "train.py" (
                        echo ✓ train.py found in root
                    ) else if exist "jenkins\\train.py" (
                        echo ✓ train.py found in jenkins/ directory
                    ) else (
                        echo ✗ train.py NOT found!
                        exit 1
                    )
                    echo.
                    echo Checking if data file exists:
                    if exist "Iris.csv" (
                        echo ✓ Iris.csv found in root
                    ) else if exist "data\\Iris.csv" (
                        echo ✓ Iris.csv found in data/ directory
                    ) else (
                        echo ✗ Iris.csv NOT found!
                        echo This is normal if the script downloads the data
                    )
                '''
            }
        }
        
        stage('Build Docker Image') {
            steps {
                echo 'Building Docker image...'
                bat '''
                    echo Building image: %DOCKER_IMAGE_TAG%
                    docker build -t %DOCKER_IMAGE_TAG% .
                    echo.
                    echo Verifying image was built:
                    docker images | findstr %DOCKER_IMAGE%
                    if errorlevel 1 (
                        echo ERROR: Docker image was not built successfully!
                        exit 1
                    )
                '''
            }
        }
        
        stage('Run Training') {
            steps {
                echo 'Starting ML training...'
                bat '''
                    echo Creating artifacts directory...
                    if not exist "artifacts" mkdir artifacts
                    
                    echo Running Docker container for training...
                    docker run --name %CONTAINER_NAME%-%BUILD_NUMBER% --rm -v "%CD%\\artifacts:/app/artifacts" %DOCKER_IMAGE_TAG%
                    
                    echo Training completed. Checking artifacts...
                    timeout /t 10 /nobreak
                    dir artifacts
                '''
            }
        }
        
        stage('Verify Artifacts') {
            steps {
                echo 'Verifying generated artifacts...'
                bat '''
                    echo Contents of artifacts directory:
                    if exist "artifacts" (
                        dir artifacts
                        echo.
                        if exist "artifacts\\iris_model.pkl" (
                            echo SUCCESS: Model file found!
                            echo File size:
                            for %%I in (artifacts\\iris_model.pkl) do echo %%~zI bytes
                        ) else (
                            echo WARNING: Model file not found in artifacts!
                            echo Checking root directory...
                            if exist "iris_model.pkl" (
                                echo ✓ Model found in root, moving to artifacts...
                                copy iris_model.pkl artifacts\\
                                echo Model moved successfully
                            ) else (
                                echo ERROR: No model file generated!
                                exit 1
                            )
                        )
                    ) else (
                        echo ERROR: Artifacts directory not found!
                        exit 1
                    )
                '''
            }
        }
        
        stage('Deploy to Server') {
            steps {
                echo 'Deploying model to server...'
                bat '''
                    echo Copying model to server directory...
                    if not exist "serveur\\models" mkdir serveur\\models
                    if exist "artifacts\\iris_model.pkl" (
                        copy artifacts\\iris_model.pkl serveur\\models\\
                        echo Model copied to server successfully
                    ) else if exist "iris_model.pkl" (
                        copy iris_model.pkl serveur\\models\\
                        echo Model copied to server successfully
                    ) else (
                        echo WARNING: No model file to copy to server
                    )
                '''
            }
        }
    }
    
    post {
        always {
            echo 'Cleaning up Docker resources...'
            bat '''
                echo Removing Docker container if still running...
                docker stop %CONTAINER_NAME%-%BUILD_NUMBER% 2>nul || echo No container to stop
                docker rm %CONTAINER_NAME%-%BUILD_NUMBER% 2>nul || echo No container to remove
                
                echo Removing Docker image: %DOCKER_IMAGE_TAG%
                docker rmi %DOCKER_IMAGE_TAG% 2>nul || echo Image already removed or not found
                
                echo Cleanup completed.
            '''
        }
        
        success {
            echo 'Pipeline completed successfully!'
            
            // Archive artifacts
            archiveArtifacts artifacts: 'artifacts/**/*', allowEmptyArchive: true
            
            // Display summary
            bat '''
                echo.
                echo =====================================
                echo        BUILD SUMMARY - SUCCESS
                echo =====================================
                echo Model trained successfully
                echo Artifacts generated:
                dir artifacts
                echo.
                echo Server models directory:
                if exist "serveur\\models" dir serveur\\models
                echo =====================================
            '''
        }
        
        failure {
            echo 'Pipeline failed!'
            
            // Debug information
            bat '''
                echo.
                echo =====================================
                echo         DEBUG INFORMATION
                echo =====================================
                echo Current directory: %CD%
                dir
                echo.
                echo Artifacts directory status:
                if exist "artifacts" (
                    echo Artifacts directory exists:
                    dir artifacts
                ) else (
                    echo Artifacts directory does not exist
                )
                echo.
                echo Docker images:
                docker images | findstr iris-train || echo No iris-train images found
                echo.
                echo Docker containers:
                docker ps -a | findstr iris-container || echo No iris-container found
                echo =====================================
            '''
        }
    }
}